# Copy this to .env and fill in your real values. .env is gitignored — never commit it.

# WireGuard interface name
WG_INTERFACE=wg0

# Path to the live WireGuard config on the server
WG_CONFIG_PATH=/etc/wireguard/wg0.conf

# Server's own WireGuard public key (from: wg show wg0 public-key)
SERVER_PUBLIC_KEY=

# How clients reach this server: your-domain-or-ip:port
SERVER_ENDPOINT=109.107.164.157:51820

# VPN subnet clients get addresses from (must match wg0.conf Address=)
VPN_SUBNET_V4=10.8.0.0/24
VPN_SUBNET_V6=fd42:42:42::/64

# DNS pushed to clients
CLIENT_DNS=1.1.1.1,8.8.8.8

# Admin panel login password (plain here, hashed automatically on first run)
ADMIN_PASSWORD=change_me

# Flask secret key for sessions — generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
FLASK_SECRET_KEY=

# Where to persist peer metadata (names, private keys for QR regen, enabled state)
PEERS_STORE_PATH=config/peers.json
